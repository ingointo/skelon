{
    "name": "@skelon/cli",
    "version": "0.1.1",
    "publishConfig": {
        "access": "public"
    },
    "description": "CLI tool for Skelon to generate skeleton templates.",
    "bin": {
        "skelon": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.js",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "commander": "^12.0.0"
    },
    "devDependencies": {
        "@skelon/core": "workspace:*"
    }
}