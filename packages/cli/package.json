{
    "name": "@skelon/cli",
    "version": "0.1.1",
    "publishConfig": {
        "access": "public"
    },
    "description": "CLI tool for Skelon to generate skeleton templates.",
    "bin": {
        "skelon": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.js",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "commander": "^12.0.0"
    },
    "keywords": [
        "cli",
        "developer-tools",
        "scaffolding",
        "ui-analysis",
        "skeleton-generator",
        "automation",
        "static-analysis",
        "skelon"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ingointo/skelon.git",
        "directory": "packages/cli"
    },
    "homepage": "https://github.com/ingointo/skelon/tree/main/packages/cli#readme",
    "bugs": {
        "url": "https://github.com/ingointo/skelon/issues"
    },
    "license": "MIT"
}