{
    "name": "@skelon/core",
    "version": "0.1.1",
    "publishConfig": {
        "access": "public"
    },
    "description": "Framework-agnostic intelligent skeleton layout detection engine.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.js",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.ts"
        }
