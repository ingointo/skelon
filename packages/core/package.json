        "skelon",
        "layout-inference",
        "geometry-engine"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ingointo/skelon.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/ingointo/skelon/tree/main/packages/core#readme",
