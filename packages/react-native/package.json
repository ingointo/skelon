{
    "name": "@skelon/react-native",
    "version": "0.1.2",
    "publishConfig": {
        "access": "public"
    },
    "description": "React Native and Expo adapter for Skelon.",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.js",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "*",
        "react-native": "*"
    },
    "dependencies": {
        "@skelon/core": "workspace:*"
    },
    "keywords": [
        "react-native",
        "react-native-skeleton",
        "mobile-loading-ui",
        "react-native-ui",
        "expo",
        "expo-skeleton",
        "native-skeleton-loader",
        "ios-skeleton",
        "android-skeleton",
        "skelon"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ingointo/skelon.git",
        "directory": "packages/react-native"
    },
    "homepage": "https://github.com/ingointo/skelon/tree/main/packages/react-native#readme",
    "bugs": {
        "url": "https://github.com/ingointo/skelon/issues"
    },
    "license": "MIT"
}